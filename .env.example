# --- Frontend (Vite) -------------------------------------------------
# Leave these blank to run the app fully on bundled MOCK data (zero setup).
# Fill them in to connect Supabase + live financial data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Force mock data even when Supabase is configured (handy for local UI work).
VITE_USE_MOCK=false

# --- Supabase Edge Function secrets (set with: supabase secrets set) ---
# Get a free key at https://www.alphavantage.co/support/#api-key
# This is NEVER exposed to the browser — it lives only in the edge function.
ALPHAVANTAGE_API_KEY=

# Exchange suffix for the data provider. Alpha Vantage uses .BSE for Indian
# listings (e.g. RELIANCE.BSE). Use .BO/.NS only if you swap providers.
EXCHANGE_SUFFIX=.BSE
